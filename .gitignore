# ── Python ─────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg-info/
dist/
build/

# ── Virtual environment ─────────────────────────────
venv/
.venv/
env/
.env/

# ── Secrets ─────────────────────────────────────────
.env
.env.*
*.pem
*.key
