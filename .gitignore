alembic/__pycache__/

# ── Testing / Locust ────────────────────────────────
.pytest_cache/
htmlcov/
.coverage
locust_report*.csv
nohup.out

# ── Editor / OS ─────────────────────────────────────
.vscode/
.idea/
*.DS_Store
Thumbs.db

# ── Logs ────────────────────────────────────────────
*.log
logs/